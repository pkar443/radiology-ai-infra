#!/usr/bin/env python3
import os
import sys


def main() -> int:
    paths = [arg for arg in sys.argv[1:] if not arg.startswith("-")]
    if not paths:
        paths = ["."]

    print("Filesystem 1024-blocks Used Available Capacity Mounted on")

    for path in paths:
        target = os.path.realpath(path)
        try:
            stats = os.statvfs(target)
        except OSError as exc:
            print(f"df: {path}: {exc.strerror}", file=sys.stderr)
            return 1

        block_size = stats.f_frsize or stats.f_bsize
        total = (block_size * stats.f_blocks) // 1024
        free = (block_size * stats.f_bfree) // 1024
        available = (block_size * stats.f_bavail) // 1024
        used = total - free
        capacity = 0 if total == 0 else round((used / total) * 100)
        print(f"userfs {total} {used} {available} {capacity}% {target}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
