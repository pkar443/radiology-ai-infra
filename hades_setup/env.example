# Copy this file to hades_setup/.env and edit as needed for this workstation.
# This file is sourced by bash, so shell expansions are allowed.

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Use one GPU by default for experimentation. Change to 0,1 if you want both visible.
CUDA_VISIBLE_DEVICES=0

# Hugging Face cache locations.
HF_HOME="${REPO_ROOT}/hf_cache"
HUGGINGFACE_HUB_CACHE="${REPO_ROOT}/hf_cache"

# Later MedGemma settings.
MEDGEMMA_MODEL_PATH=
MEDGEMMA_MODEL_ID=google/medgemma-1.5-4b-it
MODELS_DIR="${REPO_ROOT}/models"

# Optional Jupyter defaults.
JUPYTER_HOST=127.0.0.1
JUPYTER_PORT=8888

# Optional smoke test overrides.
SMOKE_TEST_MODEL_ID=distilgpt2
