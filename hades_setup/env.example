# Copy this file to hades_setup/.env and edit as needed for this workstation.
# This file is sourced by bash, so shell expansions are allowed.

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Use one GPU by default for experimentation. Change to 0,1 if you want both visible.
CUDA_VISIBLE_DEVICES=0

# Hugging Face cache locations.
HF_HOME="${REPO_ROOT}/hf_cache"
HUGGINGFACE_HUB_CACHE="${REPO_ROOT}/hf_cache"

# Later MedGemma settings.
MEDGEMMA_MODEL_PATH=
MEDGEMMA_MODEL_ID=google/medgemma-1.5-4b-it
MEDGEMMA_DEVICE_MAP=single
MODELS_DIR="${REPO_ROOT}/models"
MEDGEMMA_MAX_NEW_TOKENS=180
MEDGEMMA_DEFAULT_TEMPERATURE=0.0
MEDGEMMA_DEFAULT_TOP_P=1.0
MEDGEMMA_REPORT_MAX_NEW_TOKENS=240
MEDGEMMA_REPORT_DO_SAMPLE=false
MEDGEMMA_REPORT_TEMPERATURE=0.0
MEDGEMMA_REPORT_TOP_P=1.0
MEDGEMMA_IMAGE_REPORT_MAX_NEW_TOKENS=900
MEDGEMMA_IMAGE_REPORT_DO_SAMPLE=false
MEDGEMMA_IMAGE_REPORT_TEMPERATURE=0.0
MEDGEMMA_IMAGE_REPORT_TOP_P=1.0

# Remote inference API settings.
REMOTE_INFER_HOST=127.0.0.1
REMOTE_INFER_PORT=8009
REMOTE_INFER_AUTH_TOKEN=
REMOTE_INFER_DEBUG=false

# Optional Jupyter defaults.
JUPYTER_HOST=127.0.0.1
JUPYTER_PORT=8888

# Optional smoke test overrides.
SMOKE_TEST_MODEL_ID=distilgpt2
